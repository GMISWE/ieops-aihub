{{define "content"}}
{{with .Memory}}
<section class="pf-page-header">
  <h1>Memory <code>{{.ID}}</code></h1>
  <span class="pf-meta">
    <a href="/ui/memories{{if $.BackQuery}}?{{$.BackQuery}}{{end}}">&larr; back to memories</a>
  </span>
</section>

<div class="pf-detail-grid">
  <div>
    <div class="pf-detail-card">
      <h2>Content</h2>
      <div class="pf-content-md">
        {{if $.RenderAsMD}}
          {{.Content | md}}
        {{else}}
          <pre class="pf-content-raw">{{.Content}}</pre>
        {{end}}
      </div>
    </div>

    <div class="pf-detail-card pf-commits-card">
      <h2>Commits</h2>
      {{if $.Commits}}
      <ul class="pf-commits-list">
        {{range $.Commits}}
        {{$canMod := false}}
        {{if $.User}}
          {{if or (eq $.User.UserID .AuthorUserID) (eq $.User.Role "admin")}}{{$canMod = true}}{{end}}
        {{end}}
        <li class="pf-commit-entry">
          <div class="pf-commit-meta">
            <span class="pf-commit-author">{{default "—" .AuthorDisplay}}</span>
            <span class="pf-commit-ts">{{fmtTs .CreatedAt}}</span>
            {{if .UpdatedAt}}<span class="pf-commit-edited">(edited {{fmtTs .UpdatedAt}})</span>{{end}}
            {{if $canMod}}
            <span class="pf-commit-actions">
              <details class="pf-commit-edit">
                <summary>Edit</summary>
                <form method="POST" action="/ui/memories/{{$.Memory.ID}}/commit/{{.ID}}/edit" class="pf-commit-edit-form">
                  <textarea name="body" required>{{.Body}}</textarea>
                  <button type="submit">Save</button>
                </form>
              </details>
              <button type="button" class="pf-commit-delete-btn"
                      onclick="this.nextElementSibling.showModal()">Delete</button>
              <dialog class="pf-confirm-dialog">
                <form method="POST" action="/ui/memories/{{$.Memory.ID}}/commit/{{.ID}}/delete" class="pf-confirm-dialog-form">
                  <h3>Delete this commit?</h3>
                  <p class="pf-confirm-dialog-meta">{{default "—" .AuthorDisplay}} · {{fmtTs .CreatedAt}}</p>
                  <p class="pf-confirm-dialog-body">{{.Body}}</p>
                  <p class="pf-confirm-dialog-warn">This cannot be undone.</p>
                  <div class="pf-confirm-dialog-actions">
                    <button type="button" onclick="this.closest('dialog').close()">Cancel</button>
                    <button type="submit" class="pf-confirm-dialog-confirm">Delete</button>
                  </div>
                </form>
              </dialog>
            </span>
            {{end}}
          </div>
          <div class="pf-commit-body">{{.Body}}</div>
        </li>
        {{end}}
      </ul>
      {{else}}
      <p class="pf-empty">no commits yet.</p>
      {{end}}

      {{with $.Memory}}
      <form method="POST" action="/ui/memories/{{.ID}}/commit" class="pf-commit-form">
        <textarea name="body" rows="3" placeholder="Add a commit annotation…" required></textarea>
        <button type="submit">Add commit</button>
      </form>
      {{end}}
    </div>
  </div>

  <aside>
    <div class="pf-detail-card">
      <h2>Metadata</h2>
      <dl class="pf-kv">
        <dt>type</dt><dd><span class="pf-mem-type">{{.Type}}</span></dd>
        <dt>project</dt><dd>{{.Project}}</dd>
        <dt>visibility</dt><dd>{{.Visibility}}</dd>
        <dt>author</dt><dd>{{default "—" .AuthorDisplay}}</dd>
        <dt>created</dt><dd>{{.CreatedAt.Format "2006-01-02 15:04 MST"}}</dd>
        <dt>updated</dt><dd>{{.UpdatedAt.Format "2006-01-02 15:04 MST"}}</dd>
        <dt>strength (base)</dt><dd>{{printf "%.2f" .BaseStrength}}</dd>
        <dt>stability (days)</dt><dd>{{printf "%.1f" .StabilityDays}}</dd>
        <dt>activations</dt><dd>{{.ActivationCount}}</dd>
        <dt>immortal</dt><dd>{{.IsImmortal}}</dd>
        <dt>status</dt><dd>{{.Status}}</dd>
        {{with .WorkItemID}}
        <dt>work item</dt><dd><a href="{{wiref .}}">{{.}}</a></dd>
        {{end}}
      </dl>
    </div>
  </aside>
</div>
{{end}}

{{end}}
