<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Sign in — polyforge</title>
<style>
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue",
      sans-serif;
    background: #f6f8fa;
    color: #1f2328;
    margin: 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .login-card {
    background: #fff;
    border: 1px solid #d0d7de;
    border-radius: 8px;
    padding: 2em 2.25em;
    width: 100%;
    max-width: 420px;
    box-shadow: 0 1px 3px rgba(31, 35, 40, 0.04);
  }
  .login-card h1 {
    font-size: 1.4em;
    margin: 0 0 0.25em;
  }
  .login-card p.sub {
    color: #57606a;
    margin: 0 0 1.5em;
    font-size: 0.92em;
  }
  .login-card label {
    display: block;
    font-size: 0.85em;
    font-weight: 600;
    margin-bottom: 0.4em;
  }
  .login-card input[type=password] {
    width: 100%;
    padding: 8px 10px;
    border: 1px solid #d0d7de;
    border-radius: 6px;
    font-size: 0.95em;
    box-sizing: border-box;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
  }
  .login-card input[type=password]:focus {
    outline: none;
    border-color: #0969da;
    box-shadow: 0 0 0 3px rgba(9, 105, 218, 0.2);
  }
  .login-card button {
    background: #1f883d;
    color: #fff;
    border: 1px solid rgba(31, 35, 40, 0.15);
    border-radius: 6px;
    padding: 8px 14px;
    font-size: 0.95em;
    font-weight: 500;
    cursor: pointer;
    margin-top: 1em;
    width: 100%;
  }
  .login-card button:hover { background: #1a7f37; }
  .login-error {
    background: #ffebe9;
    border: 1px solid rgba(255, 129, 130, 0.4);
    border-radius: 6px;
    padding: 8px 12px;
    color: #82071e;
    margin-bottom: 1em;
    font-size: 0.9em;
  }
  .login-hint {
    color: #57606a;
    font-size: 0.82em;
    margin-top: 1em;
    line-height: 1.5;
  }
  .login-hint code {
    background: #afb8c133;
    padding: 1px 4px;
    border-radius: 3px;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
    font-size: 0.95em;
  }
</style>
</head>
<body>
<div class="login-card">
  <h1>Sign in to polyforge</h1>
  <p class="sub">Paste an existing API key. Same key the CLI and MCP use.</p>
  {{if .Error}}
    <div class="login-error">{{.Error}}</div>
  {{end}}
  <form method="POST" action="/ui/login">
    <input type="hidden" name="next" value="{{.Next}}">
    <label for="api_key">API key</label>
    <input type="password" id="api_key" name="api_key" autocomplete="off" autofocus
           placeholder="pf_k1_…" required>
    <button type="submit">Sign in</button>
  </form>
  <p class="login-hint">
    Issue a key with <code>polyforge user keys create</code> (admin) or copy from
    <code>~/.polyforge/credentials</code>. The session cookie is valid for 7 days.
  </p>
</div>
</body>
</html>
